        "    if cached:\n",
        "        print(\"CACHE HIT:\", sequence, detector, reid)\n",
        "        return cached\n",
        "\n",
        "    print(\"RUN:\", sequence, detector, reid)\n",
        "\n",
        "    result = run_experiment(\n",
        "        video_path, sequence,\n",
        "        detector, reid,\n",
        "        conf, cosine, budget\n",
        "    )\n",
        "\n",
        "    save_cache(key, result)\n",
        "    return result"
