      "source": [
        "with open(output_csv, \"a\", newline=\"\") as f:\n",
        "    writer = csv.DictWriter(f, fieldnames=fieldnames)\n",
        "\n",
        "    if not file_exists:\n",
        "        writer.writeheader()\n",
        "\n",
        "    for sequence_path, seq_info in SEQUENCES.items():\n",
        "\n",
        "        video_path = os.path.join(sequence_path, \"img1\")\n",
        "\n",
        "        for detector in detectors:\n",
        "            for reid in reids:\n",
        "                for conf in confidences:\n",
        "                    for cosine in cosine_distances:\n",
        "                        for budget in nn_budgets:\n",
        "\n",
        "                            try:\n",
        "                                exp = run_cached(\n",
        "                                    sequence_path,\n",
        "                                    video_path,\n",
        "                                    detector,\n",
        "                                    reid,\n",
        "                                    conf,\n",
        "                                    cosine,\n",
        "                                    budget\n",
        "                                )\n",
        "\n",
        "                                metrics = compute_metrics(\n",
        "                                    sequence_path,\n",
        "                                    exp[\"mot_file\"]\n",
        "                                )\n",
        "\n",
        "                                row = {\n",
        "                                    \"sequence\": seq_info[\"sequence\"],\n",
        "                                    \"benchmark\": seq_info[\"benchmark\"],\n",
        "                                    \"detector\": detector,\n",
        "                                    \"reid\": reid,\n",
        "                                    \"conf\": conf,\n",
        "                                    \"cosine_distance\": cosine,\n",
        "                                    \"nn_budget\": budget,\n",
        "                                    \"fps\": exp[\"fps\"],\n",
        "                                    **metrics\n",
        "                                }\n",
        "\n",
        "                                writer.writerow(row)\n",
        "                                f.flush()\n",
        "\n",
        "                                print(\n",
        "                                    f\"OK: {seq_info['sequence']} \"\n",
        "                                    f\"{detector} {reid}\"\n",
        "                                )\n",
        "\n",
        "                            except Exception as e:\n",
        "                                print(\n",
        "                                    f\"FAILED: {seq_info['sequence']} \"\n",
        "                                    f\"{detector} {reid}\"\n",
        "                                )\n",
        "                                traceback.print_exc()"
      ],
